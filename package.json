{
  "name": "barkan",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "seed:demo": "npm --workspace @barkan/api run seed:demo",
    "pm2:start-prod-api": "pm2 startOrReload ecosystem.config.cjs --only prod-barkan-api --update-env && pm2 save",
    "pm2:list": "pm2 list",
    "build": "npm --workspaces --if-present run build",
    "deploy:barkan-web": "bash scripts/deploy-barkan-web.sh",
    "deploy-barkan-web": "npm run deploy:barkan-web",
    "test": "node scripts/build-skills.mjs && node scripts/validate-skills.mjs && npm --workspaces --if-present run test",
    "e2e:integration": "npm --workspace @barkan/api run e2e:integration",
    "lint": "npm --workspaces --if-present run lint"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
