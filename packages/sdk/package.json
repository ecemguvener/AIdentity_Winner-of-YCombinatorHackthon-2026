{
  "name": "@barkan/sdk",
  "version": "0.1.0",
  "description": "Typed Node client for Barkan agent-facing APIs",
  "type": "module",
  "private": false,
  "files": ["dist", "src/generated/api.d.ts", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "build": "tsup src/index.ts src/examples/simple-agent.ts --format esm,cjs --dts --target node18",
    "test": "npm run generate && npm run build && vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "mongodb": "^6.9.0",
    "mongodb-memory-server": "^11.2.0",
    "openapi-typescript": "^7.10.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  }
}
