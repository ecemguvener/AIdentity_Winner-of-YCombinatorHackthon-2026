NODE_ENV=development
API_PORT=4001
PUBLIC_APP_URL=http://localhost:4888
PUBLIC_API_URL=http://localhost:4001
MONGODB_URI=mongodb://127.0.0.1:27017/barkan
# When NODE_ENV=production, the API uses a MongoDB database name ending in -prod.
# For example, the value above becomes mongodb://127.0.0.1:27017/barkan-prod.
SESSION_COOKIE_NAME=barkan_session
SESSION_SECRET=replace-with-a-long-random-secret
API_RATE_LIMIT_MAX=300
SENTRY_DSN=

# --- Provider modes ---------------------------------------------------------
# Set a capability to live only after all required provider keys below are set.
# Missing live keys fail API startup instead of silently falling back to mocks.
PROVIDER_MODE_EMAIL=mock
PROVIDER_MODE_PHONE=mock

# --- OpenAI -----------------------------------------------------------------
# Create keys in OpenAI Platform -> API keys.
OPENAI_API_KEY=
OPENAI_DASHBOARD_CHAT_MODEL=gpt-5.4-2026-03-05
# Model used by the payment tool to parse natural-language purchases.
# Falls back to a built-in heuristic parser when OPENAI_API_KEY is unset.
OPENAI_PAYMENTS_MODEL=gpt-4o-mini
# Model used to draft emails from plain text and summarize inbound replies.
# Falls back to a heuristic when OPENAI_API_KEY is unset.
OPENAI_EMAIL_MODEL=gpt-4o-mini

# --- Stripe billing ---------------------------------------------------------
# SaaS billing only. Agent card/Issuing capability is intentionally deferred.
# Get API keys from Stripe Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=
# Get webhook signing secret from Stripe Dashboard -> Developers -> Webhooks.
STRIPE_WEBHOOK_SECRET=

# --- Twilio phone -----------------------------------------------------------
# Get credentials from Twilio Console -> Account Info.
# Required when PROVIDER_MODE_PHONE=live.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER_COUNTRY=US
# Optional. Required by Twilio for some countries when buying/provisioning numbers.
TWILIO_ADDRESS_SID=

# --- ElevenLabs calls -------------------------------------------------------
# Get keys from ElevenLabs -> Workspace/API keys and Conversational AI agent setup.
# ELEVENLABS_API_KEY and ELEVENLABS_AGENT_ID are required when PROVIDER_MODE_PHONE=live.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ELEVENLABS_VOICE_ID=kPzsL2i3teMYv0FxEYQ6
# Optional HMAC secret for post-call and personalization webhooks.
ELEVENLABS_WORKSPACE_WEBHOOK_SECRET=

# --- Resend email -----------------------------------------------------------
# Get API key from Resend Dashboard -> API Keys.
# Required when PROVIDER_MODE_EMAIL=live.
RESEND_API_KEY=
# Agent addresses are minted as <name>-<rand>@<EMAIL_AGENT_DOMAIN>.
EMAIL_AGENT_DOMAIN=agents.barkan.dev
EMAIL_PLATFORM_FROM=Barkan <no-reply@barkan.dev>
# Get webhook signing secret from Resend Dashboard -> Webhooks.
RESEND_WEBHOOK_SECRET=
# Local sandbox redirect: deliver all outbound email to one verified recipient.
EMAIL_SANDBOX_REDIRECT_TO=
