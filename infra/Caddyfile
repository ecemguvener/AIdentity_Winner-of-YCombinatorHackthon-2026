{
	email {$CADDY_ACME_EMAIL:ops@aidentity.space}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

(web_with_api) {
	import security_headers

	@internal path /internal/*
	respond @internal 404

	@api path /api/* /webhooks/* /mcp /docs
	reverse_proxy @api 127.0.0.1:{$BARKAN_API_PORT:4000} {
		flush_interval -1
	}

	root * {$BARKAN_WEB_ROOT:/srv/barkan/current/apps/web/dist}
	encode zstd gzip
	try_files {path} /index.html
	file_server
}

{$BARKAN_WEB_HOST:aidentity.space} {
	import web_with_api
}

{$BARKAN_STAGING_WEB_HOST:staging.aidentity.space} {
	import security_headers

	@internal path /internal/*
	respond @internal 404

	@api path /api/* /webhooks/* /mcp /docs
	reverse_proxy @api 127.0.0.1:{$BARKAN_STAGING_API_PORT:4002} {
		flush_interval -1
	}

	root * {$BARKAN_STAGING_WEB_ROOT:/srv/barkan-staging/current/apps/web/dist}
	encode zstd gzip
	try_files {path} /index.html
	file_server
}
