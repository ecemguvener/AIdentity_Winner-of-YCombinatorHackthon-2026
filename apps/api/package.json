{
  "name": "@barkan/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/validate-config.ts && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed:demo": "tsx src/seed-demo.ts",
    "stripe:bootstrap-billing": "tsx src/scripts/stripe-bootstrap-billing.ts",
    "stripe:listen": "stripe listen --forward-to localhost:4001/webhooks/stripe",
    "twilio:audit": "tsx src/scripts/twilio-audit.ts",
    "usage:report": "tsx src/scripts/usage-report.ts",
    "openapi:export": "tsx src/scripts/openapi-export.ts",
    "migrate": "tsx src/migrations/run.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "mongodb": "^6.9.0",
    "resend": "^6.17.1",
    "stripe": "^22.3.0",
    "twilio": "^6.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.4",
    "@vitest/coverage-v8": "^4.1.5",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.19.1",
    "vitest": "^4.1.5"
  }
}
